#!/usr/bin/env python3
"""Run lifecycle — records start and stop timestamps/status.

Usage:
  raptor-run-lifecycle start <command> --target <path> [--out <dir>]
  raptor-run-lifecycle complete <output_dir>
  raptor-run-lifecycle fail <output_dir> [message]
  raptor-run-lifecycle cancel <output_dir>

start: resolves output directory, writes .raptor-run.json with status=running
complete: updates status=completed
fail: updates status=failed with optional error message
cancel: updates status=cancelled

This script only writes metadata. Coverage, cleanup, and reporting
are handled by their respective tools.
"""
import faulthandler
import signal
import sys
from pathlib import Path

faulthandler.enable()
if hasattr(signal, "SIGUSR1"):
    faulthandler.register(signal.SIGUSR1, all_threads=True, file=sys.stderr)

# ─── trust-marker check (do not import; inline by design) ───
import os
if not (os.environ.get("CLAUDECODE")
        or os.environ.get("_RAPTOR_TRUSTED")):
    sys.stderr.write(
        f"{sys.argv[0]}: internal dispatch script.\n"
        "  Run via 'bin/raptor' instead.\n"
        "  Tests / power users: set _RAPTOR_TRUSTED=1 to bypass.\n"
    )
    sys.exit(2)
# ─── end trust-marker check ─────────────────────────────────

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))
import core.startup.process_init  # noqa: E402,F401

from core.run.output import get_output_dir, TargetMismatchError
from core.run.metadata import start_run, complete_run, fail_run


def _merge_journal_index(out_dir: Path) -> None:
    """Merge per-run review journal into project-level index.

    No-op when the run produced no journal or when no active project
    context exists.
    """
    journal_path = out_dir / "review-journal.jsonl"
    if not journal_path.is_file():
        return
    active = Path(".active")
    if not active.is_symlink() and not active.exists():
        return
    try:
        project_dir = active.resolve()
    except OSError:
        return
    if not project_dir.is_dir():
        return
    try:
        from core.audit.journal import merge_into_index
        merged = merge_into_index(project_dir, out_dir)
        if merged:
            print(f"  journal: {merged} entries merged into project index",
                  file=sys.stderr)
    except Exception as exc:
        print(f"  journal merge skipped: {exc}", file=sys.stderr)


def main():
    if len(sys.argv) < 2:
        print(__doc__.strip(), file=sys.stderr)
        sys.exit(1)

    action = sys.argv[1]

    if action == "start":
        # Use argparse instead of the hand-rolled walker. Pre-fix the
        # walker had three subtle gaps:
        #
        # 1. `--target` with no following value: the `i + 1 < len(sys.argv)`
        #    guard kept target_path as None, then the else at the bottom
        #    advanced i by 1 — but the operator's bug ("--target" at end,
        #    no value) was silently swallowed. Argparse errors with a
        #    clear "expected one argument" message at parse time.
        # 2. `--target X positional_arg` ordering: walker accepted both
        #    forms, but `positional_arg --target X` ALSO accepted and
        #    used the positional first (then --target overrode), which
        #    invited surprises about WHICH path actually won when the
        #    operator was using both forms in scripts. Argparse
        #    rejects unknown positional args by default — the operator
        #    types one path either via flag or positional, not both.
        # 3. Unknown flags (typo `--targt`) silently consumed by the
        #    final else branch — operator's intended `--target` was
        #    never set, target_path stayed None, downstream
        #    `get_output_dir` ran without target context. Argparse
        #    errors on unknown flags by default.
        import argparse as _argparse
        parser = _argparse.ArgumentParser(
            prog="raptor-run-lifecycle start",
            description="Start a run lifecycle for a RAPTOR command",
        )
        parser.add_argument("command", help="Command name (scan|agentic|...)")
        parser.add_argument("positional_target", nargs="?", default=None,
                            help="Target path (alternative to --target)")
        parser.add_argument("--target", dest="target_flag", default=None,
                            help="Target path (preferred form)")
        parser.add_argument("--out", dest="explicit_out", default=None,
                            help="Explicit output directory override")
        parser.add_argument(
            "--max-cost-usd", dest="max_cost_usd", default=None,
            type=float,
            help="Per-run USD budget cap; pre-flight gate refuses "
                 "to start when scorecard estimate exceeds the cap",
        )
        # `sys.argv[2:]` so the `start` subcommand isn't re-parsed.
        try:
            args = parser.parse_args(sys.argv[2:])
        except SystemExit:
            # argparse already printed a clean usage message to stderr.
            raise

        # `--target` takes precedence over the positional form so a
        # script that explicitly passes `--target X` always wins.
        # Pre-fix the walker did "first one wins" via `or`, which is
        # ordering-dependent.
        target_path = args.target_flag or args.positional_target

        try:
            out_dir = get_output_dir(args.command, target_path=target_path,
                                     explicit_out=args.explicit_out)
        except TargetMismatchError as e:
            print(f"ERROR: {e}", file=sys.stderr)
            sys.exit(1)

        start_run(out_dir, args.command, target=target_path)
        print(f"OUTPUT_DIR={out_dir}")

        # Pre-flight cost gate (scorecard-derived). When
        # --max-cost-usd is set, compare against the scorecard
        # estimate. Goes to stderr so stdout stays single-line
        # OUTPUT_DIR= for callers that parse it.
        if args.max_cost_usd is not None and target_path:
            try:
                from core.run.target_types import load as _load_catalog
                from core.run.estimator import (
                    estimate_from_scorecard, format_estimate,
                )
                from core.llm.model_data import PROVIDER_DEFAULT_MODELS
                _entry = _load_catalog(Path(target_path))
                _n = _entry.typical_findings_count if _entry else 0
                if _n > 0:
                    _model = PROVIDER_DEFAULT_MODELS.get("anthropic", "")
                    _est = estimate_from_scorecard(_model, _n)
                    if _est is not None:
                        _line = format_estimate(_est)
                        if _line:
                            sys.stderr.write(_line + "\n")
                        if _est.cost_high > args.max_cost_usd:
                            sys.stderr.write(
                                f"✗ Pre-flight cost gate: scorecard "
                                f"estimate upper bound "
                                f"(${_est.cost_high:.2f}) exceeds "
                                f"--max-cost-usd cap "
                                f"(${args.max_cost_usd:.2f}). "
                                f"Raise the cap or re-run without "
                                f"--max-cost-usd.\n"
                            )
                            try:
                                fail_run(out_dir,
                                         "pre-flight cost gate exceeded")
                            except Exception:  # noqa: BLE001
                                pass
                            sys.exit(1)
            except SystemExit:
                raise
            except Exception as e:  # noqa: BLE001
                sys.stderr.write(f"  (estimate skipped: {e})\n")

    elif action == "complete":
        if len(sys.argv) < 3:
            print("Usage: raptor-run-lifecycle complete <output_dir> [--model <id>]",
                  file=sys.stderr)
            sys.exit(1)
        # Optional --model: the ambient harness model only the agent knows
        # (RAPTOR's Python can't read /model — no env var). The /understand
        # skill instructs the agent to pass its own model id here.
        rest = sys.argv[3:]
        model = rest[rest.index("--model") + 1] if (
            "--model" in rest and rest.index("--model") + 1 < len(rest)) else None
        try:
            manifest = None
            if model:
                from core.run.provenance import harness_model_entry
                entry = harness_model_entry(model)
                if entry:
                    manifest = {"models": [entry]}
            complete_run(Path(sys.argv[2]), manifest=manifest)
            # Merge review journal into project-level index (no-op when
            # no journal exists or no active project).
            _merge_journal_index(Path(sys.argv[2]))
        except Exception as e:
            print(f"ERROR: {e}", file=sys.stderr)
            sys.exit(1)

    elif action == "fail":
        if len(sys.argv) < 3:
            print("Usage: raptor-run-lifecycle fail <output_dir> [message]", file=sys.stderr)
            sys.exit(1)
        message = sys.argv[3] if len(sys.argv) > 3 else "unknown error"
        try:
            fail_run(Path(sys.argv[2]), message)
        except Exception as e:
            print(f"ERROR: {e}", file=sys.stderr)
            sys.exit(1)

    elif action == "cancel":
        if len(sys.argv) < 3:
            print("Usage: raptor-run-lifecycle cancel <output_dir>", file=sys.stderr)
            sys.exit(1)
        try:
            from core.run.metadata import cancel_run
            cancel_run(Path(sys.argv[2]))
        except Exception as e:
            print(f"ERROR: {e}", file=sys.stderr)
            sys.exit(1)

    else:
        print(f"Unknown action: {action}", file=sys.stderr)
        print("Actions: start, complete, fail, cancel", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
