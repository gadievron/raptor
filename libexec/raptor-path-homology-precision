#!/usr/bin/env python3
"""CLI shim for the path-homology validation harness (Phase 4 gate).

Run via ``bin/raptor`` (which sets ``CLAUDECODE``) or with
``_RAPTOR_TRUSTED=1`` for direct invocation in tests.

Usage:
    raptor-path-homology-precision <manifest.json> [--max-decompile N]

Manifest schema:
    {"binaries": [{"path": "/path/to/bin",
                   "vulnerable_functions": ["dfamust"]}, ...]}
"""
import os
import sys
from pathlib import Path

# ─── trust-marker check (do not import; inline by design) ───
if not (os.environ.get("CLAUDECODE")
        or os.environ.get("_RAPTOR_TRUSTED")):
    sys.stderr.write(
        f"{sys.argv[0]}: internal dispatch script.\n"
        "  Run via 'bin/raptor' instead.\n"
        "  Tests / power users: set _RAPTOR_TRUSTED=1 to bypass.\n"
    )
    sys.exit(2)
# ─── end trust-marker check ─────────────────────────────────

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from core.inventory.path_homology_precision import main  # noqa: E402

sys.exit(main())
