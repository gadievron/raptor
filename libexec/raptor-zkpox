#!/usr/bin/env python3
"""ZKPoX operator CLI — the single entry point for all tiers.

Five subcommands, one per tier of the proving stack:

    raptor-zkpox eligible [--run-dir <dir>] [--project-root <dir>]
        FREE: classify which witnesses are ZKPoX-eligible. Pure
        field-reading — no execution, no artifacts. The same summary
        the end-of-run report prints, available on demand.

    raptor-zkpox bundle <witness_store> <witness_hash> --out <dir>
        Tier 0/1: assemble a prover-ready bundle for one eligible
        witness, persisted under <out>/zkpox/<witness_hash>/.

    raptor-zkpox reproduce <bundle_dir> [--binary <path>] [--n 3]
        Tier 1.5: re-run the bundle's witness N times in the sandbox,
        confirm the recorded outcome reproduces, and fold the result
        back into the bundle manifest (bumps tier to 1.5 on success).

    raptor-zkpox prove [flags...]
        Tier 2/3: the heavy SP1 STARK proof. Currently delegates to
        ``raptor_zkpox.py prove`` (Phase 1.5 driver — drives the Rust
        prover, builds the CBOR disclosure bundle, optionally anchors
        to Sigstore Rekor). Requires the proving stack — gated by
        ``packages.zkpox.require_proving_stack``.

    raptor-zkpox verify [flags...] <bundle.cbor>
        Tier 2/3: verify a CBOR disclosure bundle via the standalone
        ``zkpox-verify`` Rust binary. Delegates to
        ``raptor_zkpox.py verify``.

The tier model lives in the package docstring
(packages/zkpox/__init__.py). Eligibility is FREE (default-on);
bundle / reproduce / prove / verify are ON-REQUEST.
"""
import faulthandler
import signal
import sys
from pathlib import Path

faulthandler.enable()
if hasattr(signal, "SIGUSR1"):
    faulthandler.register(signal.SIGUSR1, all_threads=True, file=sys.stderr)

# ─── trust-marker check (do not import; inline by design) ───
import os
if not (os.environ.get("CLAUDECODE")
        or os.environ.get("_RAPTOR_TRUSTED")):
    sys.stderr.write(
        f"{sys.argv[0]}: internal dispatch script.\n"
        "  Run via 'bin/raptor' instead.\n"
        "  Tests / power users: set _RAPTOR_TRUSTED=1 to bypass.\n"
    )
    sys.exit(2)
# ─── end trust-marker check ─────────────────────────────────

import argparse
import json
import subprocess

REPO_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(REPO_ROOT))
import core.startup.process_init  # noqa: E402,F401


def _cmd_eligible(args) -> int:
    """Tier 0 — print the free eligibility summary for a run / project.

    Resolves the same witness stores the end-of-run report uses
    (run-local + sibling runs when a project is active) and renders
    the standard "N of M witnesses are ZKPoX-eligible" block. Exits
    0 on success regardless of whether any witnesses qualify — this
    is a status query, not a gate.
    """
    from packages.zkpox import render_run_eligibility

    out_dir = Path(args.run_dir).resolve() if args.run_dir else None
    project_root = (
        Path(args.project_root).resolve() if args.project_root else None
    )
    block = render_run_eligibility(out_dir, project_root=project_root)
    if block is None:
        print("(no witnesses discovered)")
        return 0
    print(block)
    return 0


def _cmd_bundle(args) -> int:
    from core.witness import WitnessStore, WitnessStoreError
    from packages.zkpox import (
        ZKPoXBundleError,
        assemble_bundle,
        render_bundle,
        write_bundle,
    )

    store_root = Path(args.witness_store)
    if not (store_root / "manifests").is_dir():
        sys.stderr.write(
            f"not a witness store (no manifests/): {store_root}\n"
        )
        return 2

    store = WitnessStore(store_root)
    try:
        witness = store.get_witness(args.witness_hash)
    except WitnessStoreError as e:
        sys.stderr.write(f"witness lookup failed: {e}\n")
        return 2

    try:
        bundle = assemble_bundle(witness, store)
    except ZKPoXBundleError as e:
        sys.stderr.write(f"bundle assembly refused: {e}\n")
        return 1

    bundle_dir = write_bundle(bundle, store, Path(args.out))
    print(render_bundle(bundle))
    print(f"  bundle dir: {bundle_dir}")
    return 0


def _cmd_reproduce(args) -> int:
    from packages.zkpox import (
        ZKPoXBundle,
        attach_reproduction,
        render_bundle,
        reproduce_witness,
    )

    bundle_dir = Path(args.bundle_dir)
    manifest_path = bundle_dir / "manifest.json"
    witness_path = bundle_dir / "witness.bin"
    if not manifest_path.is_file():
        sys.stderr.write(f"no manifest.json in {bundle_dir}\n")
        return 2
    if not witness_path.is_file():
        sys.stderr.write(f"no witness.bin in {bundle_dir}\n")
        return 2

    try:
        manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, UnicodeDecodeError) as e:
        sys.stderr.write(f"manifest.json is not valid JSON: {e}\n")
        return 2
    if not isinstance(manifest, dict):
        sys.stderr.write("manifest.json is not a JSON object\n")
        return 2

    # The four fields reproduce_witness reads are load-bearing; a
    # manifest missing any of them is corrupt, not reproducible.
    required = ("witness_hash", "witness_len", "source", "observed_outcome")
    missing = [k for k in required if k not in manifest]
    if missing:
        sys.stderr.write(
            f"manifest.json missing required field(s): "
            f"{', '.join(missing)}\n"
        )
        return 2

    # Reconstruct the bundle dataclass from the manifest. The rest
    # round-trip for re-persistence.
    bundle = ZKPoXBundle(
        witness_hash=manifest["witness_hash"],
        witness_len=manifest["witness_len"],
        source=manifest["source"],
        observed_outcome=manifest["observed_outcome"],
        outcome_detail=manifest.get("outcome_detail", {}),
        target_binary_hash=manifest.get("target_binary_hash"),
        target_source_hash=manifest.get("target_source_hash"),
        produced_by=manifest.get("produced_by"),
        timestamp=manifest.get("timestamp"),
        attestation=manifest.get("attestation", {}),
        tier=manifest.get("tier", "0/1"),
        reproduction=manifest.get("reproduction"),
    )

    witness_bytes = witness_path.read_bytes()
    binary_path = Path(args.binary) if args.binary else None

    result = reproduce_witness(
        bundle, witness_bytes,
        binary_path=binary_path, n=args.n,
    )
    attach_reproduction(bundle, result)

    # Re-persist the manifest with the reproduction block + tier bump.
    manifest_path.write_text(
        json.dumps(bundle.as_dict(), indent=2), encoding="utf-8",
    )

    print(render_bundle(bundle))
    print(f"  reproduced: {result.reproduced} "
          f"(attempted={result.attempted}, {result.reason})")
    # Exit 0 when it reproduced; 1 when attempted-but-not; 2 when
    # not attempted (couldn't run) — so scripts can branch.
    if result.reproduced:
        return 0
    return 1 if result.attempted else 2


def _delegate_to_driver(verb: str, passthrough: list[str]) -> int:
    """Pass an unparsed argv tail straight to ``raptor_zkpox.py``.

    ``prove`` and ``verify`` are the Tier 2/3 entry points; their
    full flag schema (witness, target, wrap, vendor-pubkey, anchor
    options, …) lives in the driver and will evolve as #470 lands
    the proper bundle-centric flow. Mirroring that argparse in two
    places would just create a drift hazard. Pass everything
    through verbatim — argparse errors surface from the driver with
    a ``raptor_zkpox`` ``prog=``, which is fine for now.

    ``prove`` is gated at the dispatch layer on
    :func:`packages.zkpox.require_proving_stack`. The driver's own
    prover-binary check would still catch a missing built binary,
    but it would not surface the actionable
    ``ProvingStackUnavailable`` message that reassures the operator
    that Tiers 0/1 and 1.5 keep working without SP1 / RISC-V. The
    gate fires here so the operator sees that message at the
    operator surface — independent of whether the binary happens
    to exist on disk (e.g. a stale build from a partial install).
    ``verify`` is NOT gated: the verifier binary, once built,
    needs no part of the proving toolchain to run.

    A bare ``--help`` / ``-h`` request bypasses the gate so the
    driver's help text is always readable, even on a host without the
    proving stack installed.
    """
    is_help = any(a in ("--help", "-h") for a in passthrough)
    if verb == "prove" and not is_help:
        from packages.zkpox import require_proving_stack
        require_proving_stack()  # raises ProvingStackUnavailable on bare boxes
    driver = REPO_ROOT / "raptor_zkpox.py"
    if not driver.is_file():
        sys.stderr.write(f"driver missing: {driver}\n")
        return 2
    # RAPTOR_DIR is the driver's hard lookup (see CLAUDE.md sys.path
    # rule). When invoked under the trust-marker bypass without it
    # being set, fall back to the repo root we already resolved.
    env = dict(os.environ)
    env.setdefault("RAPTOR_DIR", str(REPO_ROOT))
    return subprocess.call(
        [sys.executable, str(driver), verb, *passthrough],
        env=env,
    )


_USAGE = (
    "usage: raptor-zkpox {eligible,bundle,reproduce,prove,verify} [args...]"
)


def main() -> int:
    # ``prove`` and ``verify`` accept the driver's full flag schema
    # verbatim. argparse REMAINDER on a subparser doesn't reliably
    # catch a leading ``--flag`` (the parent parser claims it before
    # the subparser sees it), so we peel them off before argparse
    # runs at all — preserves ``--witness …`` / ``--help`` /
    # everything as raw argv into the driver.
    argv = sys.argv[1:]
    if argv and argv[0] in ("prove", "verify"):
        return _delegate_to_driver(argv[0], argv[1:])

    ap = argparse.ArgumentParser(
        prog="raptor-zkpox",
        description=(
            "ZKPoX — eligibility, bundles, reproduction, and the "
            "Tier 2/3 proof. One dispatcher across all tiers."
        ),
        epilog=(
            "Subcommands not shown above (handled before argparse): "
            "`prove [flags...]`, `verify [flags...]` — pass-through to "
            "raptor_zkpox.py; run `raptor-zkpox prove --help` for the "
            "driver's full flag list."
        ),
    )
    sub = ap.add_subparsers(dest="cmd", required=True)

    e = sub.add_parser(
        "eligible",
        help="Tier 0 (free): show which witnesses are ZKPoX-eligible",
    )
    e.add_argument(
        "--run-dir",
        help=(
            "Run output directory whose witnesses to inspect. Default: "
            "discover from cwd / active project."
        ),
    )
    e.add_argument(
        "--project-root",
        help=(
            "Project root to scan sibling runs from (overrides the "
            "active-project default)."
        ),
    )

    b = sub.add_parser(
        "bundle",
        help="Tier 0/1: assemble a prover-ready bundle for one witness",
    )
    b.add_argument("witness_store", help="WitnessStore root dir")
    b.add_argument("witness_hash", help="sha256 of the witness bytes")
    b.add_argument("--out", required=True, help="output dir")

    r = sub.add_parser(
        "reproduce",
        help="Tier 1.5: N× reproduce the witness in the sandbox",
    )
    r.add_argument("bundle_dir", help="bundle dir (with manifest.json)")
    r.add_argument("--binary", help="target binary (FUZZ/replay sources)")
    r.add_argument(
        "--n", type=int, default=3,
        help="consecutive runs (default 3)",
    )

    args = ap.parse_args()
    if args.cmd == "eligible":
        return _cmd_eligible(args)
    if args.cmd == "bundle":
        return _cmd_bundle(args)
    if args.cmd == "reproduce":
        return _cmd_reproduce(args)
    return 2


if __name__ == "__main__":
    sys.exit(main())
