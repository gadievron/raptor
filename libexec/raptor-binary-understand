#!/usr/bin/env python3
"""Generate RAPTOR black-box binary understanding artefacts.

Usage:
  libexec/raptor-binary-understand <binary> <output-dir>
  libexec/raptor-binary-understand --binary <path> --out <dir> [options]

The old positional form remains supported. The richer flag form adds optional
Frida, fuzz, SMT and binary-diff evidence without silently executing anything.
"""

from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

# ─── trust-marker check (libexec convention) ───────────────
if not (os.environ.get("CLAUDECODE")
        or os.environ.get("_RAPTOR_TRUSTED")):                                                                                                                                                                   
    sys.stderr.write(
        f"{sys.argv[0]}: internal dispatch script.\n"                                                                                                                                                            
        "  Run via 'bin/raptor' instead.\n"                                                                                                                                                                      
        "  Tests / power users: set _RAPTOR_TRUSTED=1 to bypass.\n"
    )                                                                                                                                                                                                            
    sys.exit(2)                                               
# ─── end trust-marker check ────────────────────────────────                                                                                                                                                    

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from core.json import save_json
from packages.binary_analysis import analyse_blackbox_binary


def _parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="raptor-binary-understand",
        description="Evidence-backed black-box binary understanding.",
    )
    p.add_argument("positional_binary", nargs="?", help="Legacy binary path")
    p.add_argument("positional_out", nargs="?", help="Legacy output directory")
    p.add_argument("--binary", dest="binary_flag", help="Binary or compiled artefact to analyse")
    p.add_argument("--out", dest="out_flag", help="Output directory")
    p.add_argument("--quick", action="store_true", help="Skip full radare2 auto-analysis and xrefs")
    p.add_argument("--max-decompile", type=int, default=20, help="Maximum functions to decompile and persist (default: 20)")
    p.add_argument("--decompile-all", action="store_true", help="Persist decompiler output for every recovered function (can be slow)")
    p.add_argument("--slice-arch", help="For universal Mach-O binaries, deeply analyse this slice (for example arm64 or x86_64)")
    p.add_argument("--runtime-dir", help="Existing /frida run directory to ingest")
    p.add_argument("--fuzz-dir", help="Existing /fuzz run directory to ingest")
    p.add_argument("--constraint-file", help="JSON file with explicit SMT path conditions")
    p.add_argument("--compare", help="Compare this binary against another compiled artefact")
    return p


def main() -> int:
    args = _parser().parse_args()
    binary_arg = args.binary_flag or args.positional_binary
    out_arg = args.out_flag or args.positional_out
    if not binary_arg or not out_arg:
        print("Usage: raptor-binary-understand <binary> <output-dir>", file=sys.stderr)
        return 2

    binary = Path(binary_arg).resolve()
    out_dir = Path(out_arg).resolve()
    if not binary.exists() or not binary.is_file():
        print(f"ERROR: binary not found: {binary}", file=sys.stderr)
        return 1

    out_dir.mkdir(parents=True, exist_ok=True)

    try:
        result = analyse_blackbox_binary(
            binary,
            out_dir=out_dir,
            quick=args.quick,
            max_decompile=(1_000_000 if args.decompile_all else max(0, args.max_decompile)),
            slice_arch=args.slice_arch,
            runtime_dir=Path(args.runtime_dir).resolve() if args.runtime_dir else None,
            fuzz_dir=Path(args.fuzz_dir).resolve() if args.fuzz_dir else None,
            constraint_file=Path(args.constraint_file).resolve() if args.constraint_file else None,
            compare_binary=Path(args.compare).resolve() if args.compare else None,
        )
    except Exception as e:
        save_json(out_dir / "binary-understand-error.json", {
            "binary": str(binary),
            "error": str(e),
        })
        print(f"ERROR: binary understand failed: {e}", file=sys.stderr)
        return 1

    print(f"context-map: {out_dir / 'context-map.json'}")
    print(f"binary-context-map: {out_dir / 'binary-context-map.json'}")
    print(f"binary-manifest: {out_dir / 'binary-manifest.json'}")
    print(f"binary-evidence: {out_dir / 'binary-evidence.json'}")
    print(f"binary-decompilations: {out_dir / 'binary-decompilations.json'}")
    print(f"binary-validation-handoff: {out_dir / 'binary-validation-handoff.json'}")
    print(f"binary-graph: {result.graph_path}")
    print(f"entry_point_candidates: {len(result.context_map.get('entry_points', []))}")
    print(f"input_channels: {len(result.input_channels)}")
    print(f"sensitive_import_candidates: {len(result.context_map.get('sink_details', []))}")
    print(f"security_surface_candidates: {len(result.context_map.get('surface_details', []))}")
    print(f"candidate_flows: {len(result.context_map.get('candidate_flows', []))}")
    print(f"fuzz_witnesses: {len(result.fuzz.crashes)}")
    class_summary = (result.context_map.get("class_inventory") or {}).get("summary") or {}
    print(f"recovered_classes: {int(class_summary.get('class_count', 0))}")
    print(f"framework_callback_candidates: {len(result.context_map.get('framework_callback_candidates', []))}")
    print(
        "decompiled_functions: "
        f"{int((result.context_map.get('decompilations') or {}).get('coverage', {}).get('decompiled_functions', 0))}"
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
